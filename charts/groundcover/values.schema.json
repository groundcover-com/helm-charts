{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "groundcover chart values (partial)",
  "type": "object",
  "properties": {
    "agent": {
      "type": "object",
      "properties": {
        "gke": {
          "type": "object",
          "properties": {
            "autopilot": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "installAllowlistSynchronizer": { "type": "boolean" },
                "allowlistName": {
                  "type": "string",
                  "maxLength": 63,
                  "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9._-]*[a-zA-Z0-9])?$"
                },
                "allowlistRepoPath": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
